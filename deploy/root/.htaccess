<IfModule mod_rewrite.c>
    Options -MultiViews -Indexes
    RewriteEngine On

    # Serve frontend assets from public/ without /public in the URL
    RewriteRule ^build/(.*)$ public/build/$1 [L]
    RewriteRule ^vendor/livewire/(.*)$ public/vendor/livewire/$1 [L]
    RewriteRule ^robots\.txt$ public/robots.txt [L]

    # Serve uploads — check storage/app/public/ first (where Laravel saves files)
    RewriteCond %{DOCUMENT_ROOT}/storage/app/public/$1 -f
    RewriteRule ^storage/(.*)$ storage/app/public/$1 [L]

    # Fallback: public/storage/ (symlink or manual copy)
    RewriteCond %{DOCUMENT_ROOT}/public/storage/$1 -f
    RewriteRule ^storage/(.*)$ public/storage/$1 [L]

    # Last resort: Laravel controller
    RewriteRule ^storage/(.*)$ index.php [L]

    # Block direct web access to Laravel internals
    RewriteRule ^(?:app|bootstrap|config|database|resources|routes|tests)(?:/|$) - [F,L]
    RewriteRule ^vendor/.* - [F,L]
    RewriteRule ^(?:node_modules)(?:/|$) - [F,L]
    RewriteRule ^\.env - [F,L]
    RewriteRule ^artisan$ - [F,L]
    RewriteRule ^composer\.(?:json|lock)$ - [F,L]

    # Authorization headers
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Trailing slash redirect
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Front controller
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
