APP_NAME="MegaSol SMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/megasol-sms/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=megasol_sms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=MEGASOL
AFRICASTALKING_DEFAULT_COUNTRY_CODE=254
AFRICASTALKING_DLR_SECRET=change-me
AFRICASTALKING_SMS_QUEUE=sms
AFRICASTALKING_ENQUEUE_BULK=true

# =============================================================================
# Africa's Talking SMS
# =============================================================================
# Sandbox: username=sandbox, API key from https://account.africastalking.com
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
AFRICASTALKING_DEFAULT_COUNTRY_CODE=254
AFRICASTALKING_DLR_SECRET=change-me
AFRICASTALKING_SMS_QUEUE=sms
AFRICASTALKING_ENQUEUE_BULK=true

# =============================================================================
# PayGro (session cookie sync — not a public API)
# =============================================================================
PAYGRO_BASE_URL=https://app-main.pay-gro.com
PAYGRO_DISTRIBUTOR_COMPANY_SRL_NO=7
PAYGRO_REPORT_START_DATE=
PAYGRO_REPORT_END_DATE=
PAYGRO_REPORT_START_DAYS=60
PAYGRO_REPORT_END_DAYS=30
PAYGRO_COOKIE=
PAYGRO_ASPNET_COOKIE=
PAYGRO_USERNAME=
PAYGRO_PASSWORD=
